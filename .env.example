# NEXTAUTH Config
NEXTAUTH_URL="https://zynoraluxe.com"
NEXTAUTH_SECRET=""
COOKIE_SECRET_CURRENT=""
COOKIE_SECRET_PREVIOUS=""

# SMTP Email Configuration
SMTP_EMAIL="your-smtp-email@gmail.com"
SMTP_PASSWORD="your-smtp-app-password"

# Razorpay Test Mode Credentials
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"

# Neon PostgreSQL Database Connection URLs
# DATABASE_URL represents the pooled client URL (pgbouncer=true).
# DIRECT_URL represents the direct server endpoint (used for migrations).
DATABASE_URL=""
DIRECT_URL=""

# Sandbox GST Verification Credentials
SANDBOX_API_KEY="your-sandbox-api-key"
SANDBOX_API_SECRET="your-sandbox-api-secret"
SANDBOX_API_VERSION="1.0.0"
SANDBOX_API_BASE_URL="https://api.sandbox.co.in"

# Firebase Admin SDK Credentials
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Upstash Redis REST Credentials (for rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile Bot Challenge Credentials
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Razorpay Webhook Secret (for payment event signing)
RAZORPAY_WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary — Image CDN & Storage
# ─────────────────────────────────────────────────────────────────────────────
# Create a free account at https://cloudinary.com
# Find these values in your Cloudinary Dashboard → Settings → API Keys
#
# CLOUDINARY_CLOUD_NAME  → Your unique cloud identifier (e.g. "myshopcloud")
# CLOUDINARY_API_KEY     → Public API key (numeric, ~15 digits)
# CLOUDINARY_API_SECRET  → Private API secret — keep this server-side only
#
# These are REQUIRED for admin image uploads to work.
# Add all three to your Vercel project settings → Environment Variables.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
