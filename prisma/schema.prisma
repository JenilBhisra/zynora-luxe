generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  password           String?
  emailVerified      DateTime?
  image              String?
  role               String              @default("USER")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orders             Order[]
  reviews            Review[]
  ringConfigurations RingConfiguration[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id              String      @id @default(cuid())
  sku             String?     @unique
  name            String
  slug            String      @unique
  description     String
  price           Float
  images          String
  categoryId      String
  diamondId       String?     @unique
  diamondType     String?     @default("Lab Grown Diamond")
  metalType       String
  karatPrices     String?     @default("{}")
  availableMetals String?     @default("")
  goldPrice       Float?
  silverPrice     Float?
  platinumPrice   Float?
  stockCount      Int         @default(1)
  isFeatured      Boolean     @default(false)
  tags            String?     @default("")
  searchKeywords  String?     @default("")
  extraKeywords   String?     @default("")
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orders          OrderItem[]
  category        Category    @relation(fields: [categoryId], references: [id])
  diamond         Diamond?    @relation(fields: [diamondId], references: [id])
  reviews         Review[]
}

model Diamond {
  id                 String              @id @default(cuid())
  sku                String?             @unique
  shape              String
  caratWeight        Float
  cut                String
  clarity            String
  color              String
  certification      String
  price              Float
  stockCount         Int                 @default(1)
  stockStatus        String              @default("AVAILABLE")
  imageUrl           String?
  modelUrl           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  product            Product?
  ringConfigurations RingConfiguration[]

  @@index([price])
  @@index([caratWeight])
  @@index([shape])
  @@index([color])
  @@index([clarity])
}

model Order {
  id                String      @id @default(cuid())
  displayOrderId    String?     @unique
  orderType         String?     @default("CART")
  userId            String
  subtotal          Float?      @default(0)
  gstAmount         Float?      @default(0)
  gstType           String?
  shippingCost      Float?      @default(0)
  totalAmount       Float
  gstNumber         String?
  billingState      String?
  shippingState     String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  customerAddress   String?
  status            String      @default("PENDING")
  razorpayId        String?     @unique
  razorpayOrderId   String?     @unique
  razorpayPaymentId String?     @unique
  paymentStatus     String?     @default("PENDING")
  paymentMethod     String?
  paidAt            DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id                  String             @id @default(cuid())
  orderId             String
  productId           String?
  ringConfigurationId String?
  quantity            Int                @default(1)
  price               Float
  sku                 String?
  settingSku          String?
  diamondSku          String?
  order               Order              @relation(fields: [orderId], references: [id])
  product             Product?           @relation(fields: [productId], references: [id])
  ringConfiguration   RingConfiguration? @relation(fields: [ringConfigurationId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Setting {
  id              String              @id @default(cuid())
  sku             String?             @unique
  name            String
  description     String
  price           Float
  imageUrl        String?
  images          String?             @default("[]")
  videoUrl        String?
  modelUrl        String?
  karatPrices     String?             @default("{}")
  availableMetals String?             @default("")
  goldPrice       Float?
  silverPrice     Float?
  platinumPrice   Float?
  sizePrices      String?             @default("{}")
  stockCount      Int                 @default(1)
  category        String
  supportedShapes String?             @default("[]")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  configurations  RingConfiguration[]
}

model RingConfiguration {
  id         String      @id @default(cuid())
  userId     String?
  settingId  String
  diamondId  String
  metalType  String
  totalPrice Float
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  diamond    Diamond     @relation(fields: [diamondId], references: [id])
  setting    Setting     @relation(fields: [settingId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
}

model SiteAsset {
  key       String   @id
  url       String
  alt       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model CustomizationRequest {
  id            String   @id @default(cuid())
  productId     String?
  productName   String
  productSku    String?
  productPrice  String?
  productUrl    String?
  customerName  String
  customerEmail String
  customerPhone String
  jewelrySize   String?
  metalType     String?
  stoneType     String?
  stoneSize     String?
  engraving     String?
  requirements  String
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Shape {
  id                String   @id @default(cuid())
  name              String   @unique
  slug              String   @unique
  imageUrl          String?
  thumbnailImageUrl String?
  previewImageUrl   String?
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
